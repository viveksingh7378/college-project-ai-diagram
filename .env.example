	# Root env file used by docker-compose. Copy to .env and fill in real values.
# The server service reads these via docker-compose's `environment:` section.

# App secrets
JWT_SECRET=replace_with_a_long_random_secret

# AI provider keys — the PRIMARY analyzer now uses Groq (native JSON mode = no
# syntax errors in AI responses). Supply at least GROQ_API_KEY. The others
# are used as fallbacks by the analyzer, and by the server if it needs them.
GROQ_API_KEY=REPLACE_WITH_YOUR_GROQ_API_KEY
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional: force a specific AI provider for the analyzer.
# Values: groq | gemini | ollama  (default: auto — tries Groq first)
# AI_PROVIDER=groq

# PlantUML rendering
PLANTUML_SERVER=https://www.plantuml.com/plantuml/png
